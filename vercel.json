{
  "version": 3,
  "builds": [
    {
      "src": "frontend/ai-expense-tracker/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/[...slug].js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...slug].js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}

{
  "buildCommand": "cd frontend/ai-expense-tracker && npm install && npm run build",
  "outputDirectory": "frontend/ai-expense-tracker/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/[...slug].js"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
